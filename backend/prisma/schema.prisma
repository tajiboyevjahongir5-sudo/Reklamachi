generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id // Telegram ID
  username  String?
  firstName String?
  phoneNumber String?
  createdAt DateTime @default(now())
  
  payments  Payment[]
  listings  Listing[] @relation("ListingSeller")
  withdrawals Withdrawal[]
}

model Listing {
  id           Int      @id @default(autoincrement())
  channelName  String
  description  String?
  niche        String   @default("Boshqa")
  price        Float
  subscribers  Int      @default(0)
  monthlyViews Int      @default(0)
  youtubeUrl   String?
  monetized    Boolean  @default(false)
  createdYear  Int?
  imageUrl     String?  // Optional screenshot URL
  
  status       String   @default("ACTIVE") // ACTIVE, SOLD, HIDDEN
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  sellerId     String?
  seller       User?    @relation("ListingSeller", fields: [sellerId], references: [id])
  cardNumber   String?
  cardOwnerName String?

  payments     Payment[]
}

model Payment {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  listingId Int?
  listing   Listing? @relation(fields: [listingId], references: [id])
  amount    Float
  status    String   @default("PENDING") // PENDING, COMPLETED, CANCELLED, USED
  type      String   @default("PURCHASE") // PURCHASE, LISTING
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Settings {
  id                 Int      @id @default(1)
  cardNumber         String   @default("")
  cardOwnerName      String   @default("")
  paymentChannelId   String   @default("") // Channel ID where bank notifications are forwarded
  notifyNewPayment   Boolean  @default(true)
  notifyNewUser      Boolean  @default(true)
  
  // New dynamic pricing settings
  listingFee         Float    @default(20000)
  commissionRate     Float    @default(10) // 10%
}

model Withdrawal {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Float
  status    String   @default("PENDING") // PENDING, COMPLETED, REJECTED
  
  cardNumber String?
  cardOwnerName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
